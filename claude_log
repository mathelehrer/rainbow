  62 +    private double spectralRayRadiance(Ray ray, double lambda, int depth) {
  63 +        HitRecord record = scene.intersect(ray, new Interval(0.0001, Double.MAX_VALUE));
  64 +        if (record == null || record.objectIndex == -1) {
  65 +            // Sky emission
  66 +            Sky sky = scene.getSky();
  67 +            if (sky instanceof SpectralSky) {
  68 +                return ((SpectralSky) sky).getSpectralRadiance(ray, lambda);
  69 +            }
  70 +            // Fallback: use luminance of RGB sky color
